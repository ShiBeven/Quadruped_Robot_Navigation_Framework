<?xml version="1.0"?>
<!--
  四足机器人 URDF 模型
  TF 链: base_footprint → base_link → body → front_mid360
  四条腿的 joint 为后续步态可视化预留，当前无动力学用途

  后续仿真验证后，替换为此文件的实际四足 URDF
-->
<robot name="quadruped">
  <!-- ============================================ -->
  <!-- 躯干部分 —— TF 主干                               -->
  <!-- ============================================ -->

  <!-- base_footprint: 躯干中心在地面的垂直投影 -->
  <link name="base_footprint">
    <inertial>
      <mass value="1e-6"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>

  <!-- base_link: 躯干几何中心 (Z 偏移) -->
  <link name="base_link">
    <inertial>
      <mass value="1e-6"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
    </inertial>
  </link>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>  <!-- Z 偏移: 地面→躯干中心, 实测后调整 -->
  </joint>

  <!-- body: 躯干参考坐标系 -->
  <link name="body">
    <inertial>
      <mass value="12.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.4"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.6 0.3 0.15"/>
      </geometry>
      <material name="body_material">
        <color rgba="0.3 0.3 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_link_to_body" type="fixed">
    <parent link="base_link"/>
    <child link="body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>  <!-- identity，可设小偏移 -->
  </joint>

  <!-- front_mid360: Livox MID-360 LiDAR 安装位 -->
  <link name="front_mid360">
    <inertial>
      <mass value="0.265"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="lidar_material">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="body_to_lidar" type="fixed">
    <parent link="body"/>
    <child link="front_mid360"/>
    <!-- LiDAR 安装外参: 实测后替换 -->
    <origin xyz="0.3 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- ============================================ -->
  <!-- 腿部 —— 为后续步态可视化预留，纯 TF 框架           -->
  <!-- ============================================ -->

  <!-- 左前腿 (FL) -->
  <link name="fl_hip"/>
  <joint name="body_to_fl_hip" type="fixed">
    <parent link="body"/>
    <child link="fl_hip"/>
    <origin xyz="0.25 0.15 0" rpy="0 0 0"/>
  </joint>

  <link name="fl_knee"/>
  <joint name="fl_hip_to_knee" type="fixed">
    <parent link="fl_hip"/>
    <child link="fl_knee"/>
    <origin xyz="0 -0.05 -0.25" rpy="0 0 0"/>
  </joint>

  <link name="fl_foot"/>
  <joint name="fl_knee_to_foot" type="fixed">
    <parent link="fl_knee"/>
    <child link="fl_foot"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
  </joint>

  <!-- 右前腿 (FR) -->
  <link name="fr_hip"/>
  <joint name="body_to_fr_hip" type="fixed">
    <parent link="body"/>
    <child link="fr_hip"/>
    <origin xyz="0.25 -0.15 0" rpy="0 0 0"/>
  </joint>

  <link name="fr_knee"/>
  <joint name="fr_hip_to_knee" type="fixed">
    <parent link="fr_hip"/>
    <child link="fr_knee"/>
    <origin xyz="0 0.05 -0.25" rpy="0 0 0"/>
  </joint>

  <link name="fr_foot"/>
  <joint name="fr_knee_to_foot" type="fixed">
    <parent link="fr_knee"/>
    <child link="fr_foot"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
  </joint>

  <!-- 左后腿 (RL) -->
  <link name="rl_hip"/>
  <joint name="body_to_rl_hip" type="fixed">
    <parent link="body"/>
    <child link="rl_hip"/>
    <origin xyz="-0.25 0.15 0" rpy="0 0 0"/>
  </joint>

  <link name="rl_knee"/>
  <joint name="rl_hip_to_knee" type="fixed">
    <parent link="rl_hip"/>
    <child link="rl_knee"/>
    <origin xyz="0 -0.05 -0.25" rpy="0 0 0"/>
  </joint>

  <link name="rl_foot"/>
  <joint name="rl_knee_to_foot" type="fixed">
    <parent link="rl_knee"/>
    <child link="rl_foot"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
  </joint>

  <!-- 右后腿 (RR) -->
  <link name="rr_hip"/>
  <joint name="body_to_rr_hip" type="fixed">
    <parent link="body"/>
    <child link="rr_hip"/>
    <origin xyz="-0.25 -0.15 0" rpy="0 0 0"/>
  </joint>

  <link name="rr_knee"/>
  <joint name="rr_hip_to_knee" type="fixed">
    <parent link="rr_hip"/>
    <child link="rr_knee"/>
    <origin xyz="0 0.05 -0.25" rpy="0 0 0"/>
  </joint>

  <link name="rr_foot"/>
  <joint name="rr_knee_to_foot" type="fixed">
    <parent link="rr_knee"/>
    <child link="rr_foot"/>
    <origin xyz="0 0 -0.25" rpy="0 0 0"/>
  </joint>

</robot>
